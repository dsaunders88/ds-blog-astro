---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
    book: CollectionEntry<"books">;
}

const { book } = Astro.props;

const link = `/library/books/${book.id}`;

// import glob of all book covers to dynamically set with book id
const coverImages = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/book-covers/*.{jpeg,jpg,png}",
    { eager: true },
);
const coverImage = coverImages[`/src/assets/book-covers/${book.id}.jpg`];
---

<article class="book-preview">
    <a class="image-wrapper" href={link}>
        {
            coverImage && (
                <Image
                    alt={book.data.full_title ?? ""}
                    format="webp"
                    height={600}
                    src={coverImage.default}
                    width={400}
                />
            )
        }
    </a>
    <p class="title"><a class="title-link" href={link}>{book.data.title}</a></p>
    <p class="author">{book.data.author_refs_name}</p>
</article>

<style>
    .image-wrapper {
        position: relative;
        display: block;

        &:hover img {
            box-shadow: var(--shadow-large);
            transform: translateY(-0.75rem);
        }

        &:hover + .title a {
            color: var(--site-accent);
            text-decoration-color: var(--site-accent);
            text-underline-offset: 5px;
        }
    }

    .title {
        margin-block-start: var(--space-2xs);
        font-size: var(--step-0);
        font-family: var(--font-heading);
        font-weight: var(--font-heading-weight);
        line-height: var(--leading-tight);
    }

    .author {
        margin-block-start: 4px;
        font-size: var(--step--1);
    }
</style>
