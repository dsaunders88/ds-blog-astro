---
import { Image } from "astro:assets";
import RemoteImage from "@components/document/RemoteImage.astro";
import { getEntry } from "astro:content";
import v from "voca";

interface Props {
    id: string;
    HeadingLevel?: "h2" | "h3" | "p";
    loading?: "eager" | "lazy";
}

const { id, HeadingLevel = "h3", loading = "lazy" } = Astro.props;

const book = await getEntry("books", id);
const link = `/library/books/${book?.id}`;
---

<article class="featured-book">
    <a class="image-wrapper" href={link}>
        <RemoteImage
            alt={(book?.data.full_title as string) ?? ""}
            aspectRatio={[6, 9]}
            loading={loading}
            src={book?.data.cover?.[0].url ?? ""}
            width={600}
        />
    </a>
    <div class="text-wrapper | flow" data-tempo="allegro">
        <HeadingLevel class="title" id={v.slugify(book?.data.full_title)}>
            <a class="title-link" href={link}>{book?.data.full_title}</a>
        </HeadingLevel>
        <p class="author">{book?.data.author_refs_name}</p>
        <p class="shelves">
            <strong>Shelves: </strong>
            {
                book?.data.shelf_refs_name
                    ?.sort((a, b) => (a > b ? 1 : -1))
                    .join(", ")
            }
        </p>
    </div>
</article>

<style>
    .featured-book {
        position: relative;
        display: flex;
        align-items: center;
        gap: var(--space-l);
    }

    .image-wrapper {
        position: relative;
        flex: 0 0 16rem;

        &:hover + .text-wrapper .title a {
            color: var(--site-accent);
            text-decoration-color: var(--site-accent);
            text-underline-offset: 5px;
        }
    }

    .title {
        font-size: var(--step-2);
        font-family: var(--font-heading);
        font-weight: var(--font-heading-weight);
    }

    .author {
        --flow-space: var(--space-2xs);
    }

    .shelves {
        font-size: var(--step--1);
    }

    @media screen and (max-width: 640px) {
        .image-wrapper {
            flex-basis: 12rem;
        }
    }

    @media screen and (max-width: 500px) {
        .featured-book {
            flex-direction: column;
            align-items: flex-start;
            gap: var(--space-xs);
        }

        .image-wrapper {
            max-width: 14rem;
        }
    }
</style>
