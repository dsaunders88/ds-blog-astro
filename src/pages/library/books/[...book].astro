---
import Backlinks from "@components/posts/Backlinks.astro";
import Breadcrumbs from "@components/navigation/Breadcrumbs.astro";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import PageHeader from "@components/document/PageHeader.astro";
import PageWrapper from "@components/document/PageWrapper.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const books = await getCollection("books");

    return books.filter((book) => book.id != "recpEL2c1NdzAMRbu").map((book) => {
    // import glob of all book covers to dynamically set with book id
    const coverImages = import.meta.glob<{default: ImageMetadata}>("/src/assets/book-covers/*.{jpeg,jpg,png}", {eager: true});

    return {
        params: {
            book: book.id,
        },
        props: { book, coverImages },
    };});
}

const { book, coverImages } = Astro.props;

let backlinks: Array<CollectionEntry<"posts"> | CollectionEntry<"reviews">> =
    [];
const posts = await getCollection("posts");
const reviews = await getCollection("reviews");
const allContent = [...posts, ...reviews];
/* WARN: gonna be slow */
for (let i = 0; i < allContent.length; i++) {
    const entry = allContent[i];
    // search raw/uncompiled markdown post body and match regexp looking for book id
    // find 17-char string starting with airtable "rec"
    // switch to concatenated value using current `book.id` from dynamic route
    // find matches either enclosed in double quotes "" (i.e. featured book components) or from url slug (i.e. normal markdown links in body text)
    const regexp = new RegExp(`"${book.id}"|/library/books/${book.id}`, "g");
    const res = entry.body?.search(regexp);
    if (res !== -1) {
        backlinks.push(entry);
    }

    /* const regexp = /"(rec\S{14})*"/g; // /FeaturedBook id="(\S{17})*"/g
    const matchedBookIDs = entry.body?.matchAll(regexp);
    if (matchedBookIDs) {
        for (const match of matchedBookIDs) {
            // console.log(`Found ${match[0]}`);
            if (match[1] == book.id) {
                backlinks.push(entry);
            }
        }
    }
    */
}

const shelves = await getCollection("shelves", ({data}) => {
    return data.book_refs?.includes(book.id);
});

const coverImage = coverImages[`/src/assets/book-covers/${book.id}.jpg`];
---

<PageWrapper pageID={book.id}>
    <div class="content-wrapper paragraph">
        <Breadcrumbs collection="books" />
        <PageHeader title={book.data.full_title} type="Book" />
        <div class="author">
            <p>{book.data.author_refs_name}</p>
        </div>
        <div class="book-data">
            <div class="image-wrapper">
                {coverImage && (
                    <Image alt={book.data.full_title ?? ""} format="webp" height={900} loading="eager" src={coverImage.default} width={600} />
                )}
            </div>
            <div class="text-wrapper">
                <dl>
                    <dt><strong>Shelves</strong></dt>
                    <dd>{shelves.sort((a, b) => a.data.name > b.data.name ? 1 : -1).map((shelf, idx) => (
                        <a href={`/library/shelves/${shelf.id}`}>{shelf.data.name}</a>
                        <Fragment>
                            {idx !== shelves.length - 1 && (
                                <span class="shelf-comma">, </span>
                            )}
                        </Fragment>
                    ))}</dd>
                    {book.data.series_name && (
                        <dt><strong>Series</strong></dt>
                        <dd>{`#${book.data.series_number} in ${book.data.series_name}`}</dd>
                    )}
                    <dt><strong>Pages</strong></dt>
                    <dd>{book.data.page_count}</dd>
                    <dt><strong>Edition</strong></dt>
                    <dd>
                        {book.data.publisher ? `${book.data.publisher} (${book.data.publish_date})` : `${book.data.publish_date}`}
                    </dd>
                    {book.data.edition_notes && (
                        <dt><strong>Edition Notes</strong></dt>
                        <dd>{book.data.edition_notes}</dd>
                    )}
                    <dt><strong>ISBN</strong></dt>
                    <dd>{book.data.isbn}</dd>
                    <dt><strong>Format</strong></dt>
                    <dd>{book.data.format}</dd>
                    <dt><strong>Own?</strong></dt>
                    <dd>{book.data.own ? "Yes" : "No"}</dd>
                    {book.data.open_library_url && (
                        <dt><strong>Open Library</strong></dt>
                        <dd>
                            <a
                                href={book.data.open_library_url}
                                target="_blank"
                            >
                                {book.data.open_library_id ?? "Link"}
                            </a>
                        </dd>
                    )}
                </dl>
            </div>
        </div>
    </div>
    <div class="post-footer | content-wrapper paragraph">
        {
            backlinks.length > 0 && (
                <Backlinks backlinks={backlinks} type="books" />
            )
        }
    </div>
</PageWrapper>

<style>
    .author {
        margin-block-start: var(--space-xs);
        font-size: var(--step-1);
    }

    .book-data {
        margin-block-start: var(--space-l);
        display: flex;
        gap: var(--space-l);
    }

    :global(.book-data img) {
        border-radius: var(--rounded-xs);
    }

    .image-wrapper {
        flex: 0 0 18rem;
        /* width: 18rem; */
        border-radius: var(--rounded-xs);
    }

    .text-wrapper {
        /* flex-grow: 1; */
        flex-shrink: 1;
        font-size: var(--step--1);

        & dl {
            display: grid;
            grid-template-columns: 7rem 1fr;
            column-gap: 1rem;
            row-gap: var(--space-3xs);
        }
    }

    .shelf-comma {
        margin-left: -2px;
        margin-right: 2px;
    }

    @media screen and (max-width: 768px) {
        .book-data {
            flex-direction: column;
            gap: var(--space-m);
        }
    }
</style>
